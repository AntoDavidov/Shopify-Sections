<section class="sticky-split-images-{{ section.id }}">
  <div class="sticky-split-images__inner">
    
    <div class="sticky-split-images__sticky-text">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="sticky-split-images__images">
        <div class="sticky-split-images__image">
            {% assign left_desktop = section.settings.left_image %}
            {% assign left_mobile = section.settings.left_image_mobile %}

            {% if left_desktop != blank %}
            <picture>
                {% unless section.settings.mobile_image_choice == 'right' %}
                  {% if left_mobile != blank %}
                    <source media="(max-width: 749px)" srcset="{{ left_mobile | image_url: width: 900 }}">
                  {% endif %}
                {% endunless %}
                {{ left_desktop | image_url: width: 2000 | image_tag: loading: 'lazy', alt: section.settings.heading }}
            </picture>
            {% else %}
            <div class="sticky-split-images__placeholder">Left image</div>
            {% endif %}
        </div>

      <div class="sticky-split-images__image">
        {% assign right_desktop = section.settings.right_image %}
        {% assign right_mobile = section.settings.right_image_mobile %}

        {% if right_desktop != blank %}
          <picture>
            {% unless section.settings.mobile_image_choice == 'left' %}
              {% if right_mobile != blank %}
                <source media="(max-width: 749px)" srcset="{{ right_mobile | image_url: width: 900 }}">
              {% endif %}
            {% endunless %}
            {{ right_desktop | image_url: width: 2000 | image_tag: loading: 'lazy', alt: section.settings.heading }}
          </picture>
        {% else %}
          <div class="sticky-split-images__placeholder">Right image</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .sticky-split-images-{{ section.id }} {
    position: relative;
  }

  .sticky-split-images-{{ section.id }} .sticky-split-images__inner {
    position: relative;
    height: {{ section.settings.scroll_height }}vh;
  }

  .sticky-split-images-{{ section.id }} .sticky-split-images__sticky-text {
    position: sticky;
    top: {{ section.settings.text_position_desktop }}px;
    z-index: 3;
    text-align: center;
    padding: 20px 16px 0;
    pointer-events: none;
  }

  .sticky-split-images-{{ section.id }} .sticky-split-images__sticky-text h2 {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ section.settings.heading_color }};
  }

  .sticky-split-images-{{ section.id }} .sticky-split-images__images {
    position: absolute;
    inset: 0;
    display: flex;
  }

  .sticky-split-images-{{ section.id }} .sticky-split-images__image {
    width: 50%;
    height: 100%;
    overflow: hidden;
  }

  .sticky-split-images-{{ section.id }} .sticky-split-images__image picture,
  .sticky-split-images-{{ section.id }} .sticky-split-images__image img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .sticky-split-images-{{ section.id }} .sticky-split-images__image img {
    object-fit: cover;
  }

  .sticky-split-images-{{ section.id }} .sticky-split-images__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f3f3;
    color: #777;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .sticky-split-images-{{ section.id }} .sticky-split-images__inner {
      height: {{ section.settings.scroll_height_mobile }}vh;
    }

    .sticky-split-images-{{ section.id }} .sticky-split-images__sticky-text {
      top: {{ section.settings.text_position_mobile }}px;
      padding: 12px 12px 0;
    }

    .sticky-split-images-{{ section.id }} .sticky-split-images__sticky-text h2 {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
    {% if section.settings.mobile_image_choice == 'left' %}
      .sticky-split-images-{{ section.id }} .sticky-split-images__image:last-child {
        display: none;
      }
      .sticky-split-images-{{ section.id }} .sticky-split-images__image:first-child {
        width: 100%;
      }
    {% elsif section.settings.mobile_image_choice == 'right' %}
      .sticky-split-images-{{ section.id }} .sticky-split-images__image:first-child {
        display: none;
      }
      .sticky-split-images-{{ section.id }} .sticky-split-images__image:last-child {
        width: 100%;
      }
    {% endif %}
  }
</style>

{% schema %}
{
    "name": "AD - Sticky split images",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Your text here"
        },
        {
            "type": "image_picker",
            "id": "left_image",
            "label": "Left image"
        },
        {
            "type": "image_picker",
            "id": "right_image",
            "label": "Right image"
        },
        {
            "type": "image_picker",
            "id": "left_image_mobile",
            "label": "Left mobile image"
        },
        {
            "type": "image_picker",
            "id": "right_image_mobile",
            "label": "Right mobile image"
        },
        {
            "type": "select",
            "id": "mobile_image_choice",
            "label": "Mobile: show single image",
            "info": "Choose which image displays on mobile. Upload a matching mobile image above for best results.",
            "options": [
                { "value": "both", "label": "Both images" },
                { "value": "left", "label": "Left image only" },
                { "value": "right", "label": "Right image only" }
            ],
            "default": "both"
        },
        {
            "type": "range",
            "id": "scroll_height",
            "label": "Desktop section height",
            "min": 60,
            "max": 400,
            "step": 10,
            "unit": "vh",
            "default": 60
        },
        {
            "type": "range",
            "id": "scroll_height_mobile",
            "label": "Mobile section height",
            "min": 30,
            "max": 300,
            "step": 10,
            "unit": "vh",
            "default": 30
        },
        {
            "type": "range",
            "id": "text_position_desktop",
            "label": "Text vertical position (desktop)",
            "info": "Higher value = text appears lower on screen while scrolling",
            "min": 0,
            "max": 500,
            "step": 10,
            "unit": "px",
            "default": 400
        },
        {
            "type": "range",
            "id": "text_position_mobile",
            "label": "Text vertical position (mobile)",
            "info": "Higher value = text appears lower on screen while scrolling",
            "min": 0,
            "max": 300,
            "step": 10,
            "unit": "px",
            "default": 250
        },
        {
            "type": "range",
            "id": "heading_size",
            "label": "Desktop heading size",
            "min": 18,
            "max": 80,
            "step": 2,
            "unit": "px",
            "default": 36
        },
        {
            "type": "range",
            "id": "heading_size_mobile",
            "label": "Mobile heading size",
            "min": 14,
            "max": 40,
            "step": 1,
            "unit": "px",
            "default": 24
        },
        {
            "type": "color",
            "id": "heading_color",
            "label": "Heading color",
            "default": "#ffffff"
        }
    ],
    "presets": [
        {
            "name": "AD - Sticky split images"
        }
    ]
}
{% endschema %}
